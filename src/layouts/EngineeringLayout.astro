---
import BaseLayout from './BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import { SITE } from '../config/site';

export interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  path?: string;
}
---

<BaseLayout
  title={`${Astro.props.title} — Engineering — ${SITE.author}`}
  description={Astro.props.description}
  path={Astro.props.path}
>
  <Container>
    <article class="engineering">
      <header class="header">
        <a href="/engineering" class="back">&larr; Engineering</a>
        <time datetime={Astro.props.date.toISOString()} class="date">
          {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(Astro.props.date)}
        </time>
        <h1 class="title">{Astro.props.title}</h1>
        <p class="description">{Astro.props.description}</p>
        <div class="tags">
          {Astro.props.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </header>
      <div class="body">
        <slot />
      </div>
    </article>
  </Container>
</BaseLayout>

<style>
  .engineering {
    padding: 48px 0 96px;
    max-width: 720px;
  }
  .header {
    margin-bottom: 48px;
  }
  .back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 24px;
    text-decoration: none;
  }
  .back:hover {
    color: var(--accent);
  }
  .date {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }
  .title {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 16px;
  }
  .description {
    color: var(--text-secondary);
    margin-bottom: 24px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-secondary);
    padding: 4px 10px;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: var(--bg-tertiary);
  }
  .body :global(h2) {
    margin-top: 48px;
    margin-bottom: 16px;
  }
  .body :global(h3) {
    margin-top: 32px;
    margin-bottom: 12px;
  }
  .body :global(p) {
    margin-bottom: 16px;
  }
  .body :global(pre) {
    margin: 24px 0;
  }
  .body :global(code) {
    font-size: 0.8125rem;
  }
  .body :global(ul) {
    margin-bottom: 16px;
    padding-left: 20px;
  }
  .body :global(li) {
    margin-bottom: 8px;
  }
  .body :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 16px;
    margin: 24px 0;
    color: var(--text-secondary);
  }
  @media (max-width: 768px) {
    .title {
      font-size: 1.5rem;
    }
  }
</style>
