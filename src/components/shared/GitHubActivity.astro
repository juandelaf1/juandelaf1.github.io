---
import { fetchRepos } from '../../lib/github';
import type { GitHubRepo } from '../../lib/github';

const repos: GitHubRepo[] = await fetchRepos();
const pinned = repos.slice(0, 4);

const langColors: Record<string, string> = {
  Python: '#3572A5', TypeScript: '#3178C6', JavaScript: '#F7DF1E',
  Rust: '#DEA584', Shell: '#89E051', HTML: '#E34F26',
  CSS: '#563D7C', Jupyter: '#DA5B0B', SQL: '#E38C00',
};

function languageColor(lang: string): string {
  return langColors[lang] || '#8B8B8B';
}
---

<section class="github">
  <h2 class="heading">Open Source</h2>
  <p class="subtitle">Recent public repositories</p>
  <div class="grid">
    {pinned.length > 0 ? pinned.map((repo) => (
      <a href={repo.html_url} target="_blank" rel="noopener noreferrer" class="card">
        <div class="card-header">
          <svg class="icon" viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path fill-rule="evenodd" d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 010-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 011-1h8zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z"/></svg>
          <span class="name">{repo.name}</span>
        </div>
        {repo.description && <p class="desc">{repo.description}</p>}
        <div class="meta">
          {repo.language && <span class="lang" style={`--dot-color: ${languageColor(repo.language)}`}>{repo.language}</span>}
          <span class="stars">{repo.stargazers_count > 0 ? `${repo.stargazers_count} ★` : ''}</span>
        </div>
      </a>
    )) : <p class="empty">No public repositories to show.</p>}
  </div>
</section>

<style>
  .github {
    padding: 48px 0;
    border-top: 1px solid var(--border);
  }

  .heading {
    font-size: 1.125rem;
    font-weight: 600;
  }

  .subtitle {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-top: 4px;
    margin-bottom: 24px;
  }

  .grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  .card {
    display: block;
    padding: 16px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    text-decoration: none;
    transition: border-color var(--transition), background var(--transition);
  }

  .card:hover {
    border-color: var(--text-secondary);
    background: var(--surface);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .icon {
    color: var(--text-secondary);
    flex-shrink: 0;
  }

  .name {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--text-primary);
  }

  .desc {
    color: var(--text-secondary);
    font-size: 0.8125rem;
    line-height: 1.5;
    margin-top: 8px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 12px;
    font-size: 0.75rem;
  }

  .lang {
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .lang::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--dot-color, #8B8B8B);
  }

  .stars {
    color: var(--text-secondary);
  }

  .empty {
    color: var(--text-secondary);
    font-size: 0.875rem;
  }
</style>
