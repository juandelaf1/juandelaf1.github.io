---
import Metric from '../ui/Metric.astro';

export interface Props {
  metrics: Array<{ value: string; label: string }>;
}
---

<div class="metrics-row">
  {Astro.props.metrics.map((m) => (
    <Metric value={m.value} label={m.label} />
  ))}
</div>

<style>
  .metrics-row {
    display: flex;
    gap: 48px;
    padding: 32px 0;
    flex-wrap: wrap;
  }
  @media (max-width: 768px) {
    .metrics-row {
      gap: 24px;
    }
  }
</style>
