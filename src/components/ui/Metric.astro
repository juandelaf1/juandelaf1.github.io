---
export interface Props {
  value: string;
  label: string;
  class?: string;
}
---

<div class:list={['metric', Astro.props.class]}>
  <span class="value">{Astro.props.value}</span>
  <span class="label">{Astro.props.label}</span>
</div>

<style>
  .metric {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .value {
    font-family: var(--font-sans);
    font-size: 2rem;
    font-weight: 800;
    color: var(--metric);
    line-height: 1.1;
  }
  .label {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.3;
  }
  @media (max-width: 768px) {
    .value {
      font-size: 1.5rem;
    }
  }
</style>
