---
import type { CollectionEntry } from 'astro:content';
import Metric from '../ui/Metric.astro';

export interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
const sorted = projects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<section class="selected-work">
  <h2 class="heading">Selected Work</h2>
  <div class="grid">
    {sorted.map((project) => (
      <a href={`/projects/${project.id}`} class="card">
        <div class="card-content">
          <div class="card-header">
            <span class="category">{project.data.category}</span>
          </div>
          <h3 class="card-title">{project.data.title}</h3>
          <p class="card-description">{project.data.description}</p>
          {project.data.metrics.length > 0 && (
            <div class="card-metrics">
              {project.data.metrics.slice(0, 2).map((m) => (
                <Metric value={m.value} label={m.label} />
              ))}
            </div>
          )}
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .selected-work {
    padding: 0 0 96px;
  }
  .heading {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .card {
    display: block;
    background: var(--bg-primary);
    padding: 32px;
    text-decoration: none;
    transition: background var(--transition);
  }
  .card:hover {
    background: var(--bg-secondary);
  }
  .card-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .category {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
  }
  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .card-description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .card-metrics {
    display: flex;
    gap: 24px;
    margin-top: 8px;
  }
  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .card {
      padding: 24px;
    }
  }
</style>
